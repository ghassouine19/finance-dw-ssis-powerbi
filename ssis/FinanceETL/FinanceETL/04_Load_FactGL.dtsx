      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{DDE8D7DE-C646-43E9-810A-397F7B14AB63}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL_Load_FactGL"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{C712AFF1-152C-4215-80A2-2530B55AA3F4}"
          SQLTask:SqlStatementSource="/* pour éviter doublons si tu relances */&#xA;TRUNCATE TABLE dw.factGL;&#xA;&#xA;/* ACTUAL */&#xA;INSERT INTO dw.factGL (DateKey, CompanyKey, CostCenterKey, AccountKey, Scenario, Amount)&#xA;SELECT&#xA;    CONVERT(int, FORMAT(a.TxnDate, 'yyyyMMdd')) AS DateKey,&#xA;    c.CompanyKey,&#xA;    cc.CostCenterKey,&#xA;    ga.AccountKey,&#xA;    'ACTUAL' AS Scenario,&#xA;    a.Amount&#xA;FROM stg.gl_actuals a&#xA;JOIN dw.dimCompany c     ON c.CompanyCode = a.CompanyCode&#xA;JOIN dw.dimCostCenter cc ON cc.CostCenter = a.CostCenter&#xA;JOIN dw.dimGLAccount ga  ON ga.GLAccount  = a.GLAccount;&#xA;&#xA;/* BUDGET */&#xA;INSERT INTO dw.factGL (DateKey, CompanyKey, CostCenterKey, AccountKey, Scenario, Amount)&#xA;SELECT&#xA;    CONVERT(int, FORMAT(b.TxnDate, 'yyyyMMdd')) AS DateKey,&#xA;    c.CompanyKey,&#xA;    cc.CostCenterKey,&#xA;    ga.AccountKey,&#xA;    'BUDGET' AS Scenario,&#xA;    b.BudgetAmount&#xA;FROM stg.gl_budget b&#xA;JOIN dw.dimCompany c     ON c.CompanyCode = b.CompanyCode&#xA;JOIN dw.dimCostCenter cc ON cc.CostCenter = b.CostCenter&#xA;JOIN dw.dimGLAccount ga  ON ga.GLAccount  = b.GLAccount;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
