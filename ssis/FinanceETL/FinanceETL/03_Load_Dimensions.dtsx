  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\SQL_Load_Dimensions"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tâche d'exécution de requêtes SQL"
      DTS:DTSID="{3A38DEE0-614C-43CE-A9F3-91703ECFDDF5}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="1033"
      DTS:ObjectName="SQL_Load_Dimensions"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{A633E048-5F18-413C-A2DB-BD2DF14721AC}"
          SQLTask:SqlStatementSource="/* dimDate */&#xA;;WITH d AS (&#xA;    SELECT CAST('2025-01-01' AS date) AS [Date]&#xA;    UNION ALL&#xA;    SELECT DATEADD(day, 1, [Date])&#xA;    FROM d&#xA;    WHERE [Date] &lt; '2026-12-31'&#xA;)&#xA;INSERT INTO dw.dimDate (DateKey, [Date], [Year], [Month], MonthName, [Quarter])&#xA;SELECT&#xA;    CONVERT(int, FORMAT([Date], 'yyyyMMdd')) AS DateKey,&#xA;    [Date],&#xA;    DATEPART(year, [Date]) AS [Year],&#xA;    DATEPART(month, [Date]) AS [Month],&#xA;    DATENAME(month, [Date]) AS MonthName,&#xA;    DATEPART(quarter, [Date]) AS [Quarter]&#xA;FROM d&#xA;WHERE NOT EXISTS (SELECT 1 FROM dw.dimDate x WHERE x.[Date] = d.[Date])&#xA;OPTION (MAXRECURSION 4000);&#xA;&#xA;/* dimCompany */&#xA;INSERT INTO dw.dimCompany (CompanyCode)&#xA;SELECT DISTINCT s.CompanyCode&#xA;FROM (&#xA;    SELECT CompanyCode FROM stg.gl_actuals&#xA;    UNION&#xA;    SELECT CompanyCode FROM stg.gl_budget&#xA;) s&#xA;WHERE NOT EXISTS (SELECT 1 FROM dw.dimCompany d WHERE d.CompanyCode = s.CompanyCode);&#xA;&#xA;/* dimCostCenter */&#xA;INSERT INTO dw.dimCostCenter (CostCenter)&#xA;SELECT DISTINCT s.CostCenter&#xA;FROM (&#xA;    SELECT CostCenter FROM stg.gl_actuals&#xA;    UNION&#xA;    SELECT CostCenter FROM stg.gl_budget&#xA;) s&#xA;WHERE NOT EXISTS (SELECT 1 FROM dw.dimCostCenter d WHERE d.CostCenter = s.CostCenter);&#xA;&#xA;/* dimGLAccount */&#xA;INSERT INTO dw.dimGLAccount (GLAccount, AccountType)&#xA;SELECT DISTINCT s.GLAccount,&#xA;       CASE&#xA;         WHEN LEFT(s.GLAccount, 1) = '4' THEN 'Revenue'&#xA;         WHEN LEFT(s.GLAccount, 1) = '5' THEN 'COGS'&#xA;         WHEN LEFT(s.GLAccount, 1) = '6' THEN 'OPEX'&#xA;         ELSE 'Other'&#xA;       END&#xA;FROM (&#xA;    SELECT GLAccount FROM stg.gl_actuals&#xA;    UNION&#xA;    SELECT GLAccount FROM stg.gl_budget&#xA;) s&#xA;WHERE NOT EXISTS (SELECT 1 FROM dw.dimGLAccount d WHERE d.GLAccount = s.GLAccount);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
